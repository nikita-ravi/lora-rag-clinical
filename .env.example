# Copy this file to .env and fill in your values

# Required for BioASQ data loading
BIOASQ_DATA_PATH=/path/to/bioasq/data

# Required for online mode (optional with --offline flag)
WANDB_API_KEY=your_wandb_api_key
WANDB_PROJECT=lora-rag-clinical
HF_TOKEN=your_huggingface_token

# Required for synthetic data generation (M4)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: for LLM-as-judge faithfulness metric
# Uses same ANTHROPIC_API_KEY as above
